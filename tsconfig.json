{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext"],
    "types": ["bun", "node"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@core/*": ["./src/core/*"],
      "@logic/*": ["./src/logic/*"],
      "@server/*": ["./src/server/*"]
    }
  },
  "include": ["src", "test", "vitest.config.ts"],
  "exclude": ["node_modules"]
}
