{
  "name": "mangou-ai-motion-comics",
  "version": "3.0.0-local",
  "private": false,
  "description": "Mangou AI Motion Comics - main product repo with skill docs, providers, CLI/runtime, and workspace template",
  "license": "FSL-1.1-Apache-2.0",
  "homepage": "https://www.mangou.art",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MangouArt/mangou-ai-motion-comics.git"
  },
  "bugs": {
    "url": "https://github.com/MangouArt/mangou-ai-motion-comics/issues",
    "email": "mangou@mangou.art"
  },
  "keywords": [
    "ai",
    "motion-comic",
    "storyboard",
    "agent",
    "skill",
    "yaml",
    "provider",
    "runtime",
    "mangou"
  ],
  "engines": {
    "bun": ">=1.1"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "bun run mangou -- server start",
    "mangou": "bun run src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "ci": "bun run typecheck && bun run test && bun run build",
    "project:init": "bun run mangou -- project init",
    "project:stitch": "bun run mangou -- project stitch",
    "storyboard:generate": "bun run mangou -- storyboard generate",
    "storyboard:split": "bun run mangou -- storyboard split",
    "asset:generate": "bun run mangou -- asset generate",
    "server:start": "bun run mangou -- server start"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "@tanstack/react-query": "5.95.2",
    "@vercel/analytics": "^2.0.1",
    "antd": "6.3.3",
    "axios": "^1.14.0",
    "chokidar": "5.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dotenv": "^17.3.1",
    "framer-motion": "11.18.2",
    "https-proxy-agent": "^8.0.0",
    "js-yaml": "4.1.1",
    "lucide-react": "0.563.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "10.1.0",
    "react-router-dom": "6.30.3",
    "tailwind-merge": "2.6.1",
    "tailwindcss-animate": "1.0.7",
    "undici": "^7.24.6",
